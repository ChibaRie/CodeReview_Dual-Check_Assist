{
  "name": "dualcheck-code",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "cd web && npm run dev",
    "dev:server": "python web_server.py",
    "build": "cd web && npm run build",
    "install:all": "npm install && cd web && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}